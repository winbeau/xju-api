# scripts/.env.example — 复制为 scripts/.env 并填真实值(真实 .env 被 .gitignore 排除,永不入库)

# L1 new-api 入口
NEWAPI_BASE="https://api.selab.top"

# 访问令牌: new-api 控制台「个人设置」页生成的 access_token
# 模型A(PLAN.md §4.4): 一个 access_token 只能给自己名下建卡 —— 给哪个用户发卡,就用那个用户的 access_token
ACCESS_TOKEN="__ACCESS_TOKEN__"

# 上面 access_token 对应的 new-api 用户 ID(个人设置页可见)
# new-api 的 API 鉴权要求同时携带 New-Api-User 头(middleware/auth.go)
NEWAPI_USER_ID="__USER_ID__"
