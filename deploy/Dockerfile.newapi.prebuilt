# deploy/Dockerfile.newapi.prebuilt — Go-only 构建,前端产物预构建后 COPY 进来
#
# 唯一镜像构建路径(全量 Dockerfile 已删,git 历史可找回):
# deploy/build-newapi.sh 先构建前端并把产物放入 server/newapi/prebuilt/dist,
# 再由本 Dockerfile 编译 Go。SKIP_WEB=1 时可复用外部搬入的现有前端产物。
#
# 构建(上下文 = server/newapi/):
#   docker build -f deploy/Dockerfile.newapi.prebuilt -t winbeau/xju-newapi:<tag> server/newapi
# 前置: server/newapi/prebuilt/dist(顶层 web/ 的构建产物)。
#
# 护栏: 未改动 new-api/QuantumNous 品牌/归属;/licenses 链路原样保留。

FROM golang:1.26.1-alpine AS builder
ENV GO111MODULE=on CGO_ENABLED=0
ARG TARGETOS
ARG TARGETARCH
ENV GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH:-amd64}
ENV GOEXPERIMENT=greenteagc

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# 用预构建产物覆盖 go:embed 接收槽(context 的 .dockerignore 排除了 web/dist,
# 树内只有占位 index.html,这里 COPY 真产物进去)
COPY prebuilt/dist ./web/dist
# -p 2 限制并行编译,压低 tri 上的峰值内存
RUN go build -p 2 -ldflags "-s -w -X 'github.com/QuantumNous/new-api/common.Version=$(cat VERSION)'" -o new-api

FROM debian:bookworm-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates tzdata libasan8 wget \
    && rm -rf /var/lib/apt/lists/* \
    && update-ca-certificates
COPY --from=builder /build/new-api /
COPY LICENSE NOTICE THIRD-PARTY-LICENSES.md /licenses/
EXPOSE 3000
WORKDIR /data
ENTRYPOINT ["/new-api"]
