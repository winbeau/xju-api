# deploy/Caddyfile — xju-api 唯一公网入口(claude-tri)
# 安装位置: /etc/caddy/Caddyfile ; 改完 `caddy validate --config /etc/caddy/Caddyfile` 再 reload
# 前置(PLAN.md §3.2): api/codex 两条 A 记录已指向 70.39.193.15,且 Cloudflare 首签期设「仅 DNS/灰云」
#
# 日志: 走默认 stderr → journald(`journalctl -u caddy`),不写日志文件。
#   发行版 caddy.service 的沙箱(User=caddy + ProtectSystem=full,无 ReadWritePaths)拒绝
#   caddy 进程写日志文件 —— /var/log/caddy 与 /var/lib/caddy/logs 实测均 permission denied,
#   加 LogsDirectory/ReadWritePaths drop-in 亦无效。journald 自带容量上限,同样满足
#   PLAN.md §3.3「控制日志膨胀」的诉求。
{
	email __ACME_EMAIL__
}

# ---------- L1 发卡/统计前台 (new-api) ----------
api.selab.top {
	encode zstd gzip

	reverse_proxy 127.0.0.1:3000 {
		header_up X-Real-IP {remote_host}
		# new-api 原生健康端点
		health_uri /api/status
		health_interval 30s
	}
}

# ---------- L2/L3 协议中转 + 号池 (CLIProxyAPI) ----------
codex.selab.top {
	encode zstd gzip

	# CLIProxyAPI 无专用健康端点(PLAN.md §3.3),不设主动健康检查
	reverse_proxy 127.0.0.1:8317 {
		header_up X-Real-IP {remote_host}
	}
}
